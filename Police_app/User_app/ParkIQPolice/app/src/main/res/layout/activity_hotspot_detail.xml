<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:background="@drawable/rounded_surface_background">

        <!-- Header with top margin -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/primary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtJunction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Delmia Circle"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtStation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="J.P Nagar Police Station"
                    android:textColor="@color/surface"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 ACTIVE NOW"
                    android:textColor="#C8E6C9"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="120dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/alertHigh"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Priority Score"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/txtScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.74"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="120dp"
                app:cardBackgroundColor="@color/alertMedium"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Violations"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/txtViolations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Peak Hour -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕒 Peak Hour"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtPeakHour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textSize="24sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Recommendation Card (initially hidden) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/recommendationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtRecommendation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/btnMaps"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🗺 Open Maps"
            android:layout_marginTop="20dp"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnDeploy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📋 Generate Deployment Plan"
            android:layout_marginTop="10dp"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/secondary"
            android:textColor="@color/white"/>

        <!-- NEW Approve Deployment button (hidden by default) -->
        <Button
            android:id="@+id/btnApprove"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="✅ Approve Deployment"
            android:visibility="gone"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"/>

    </LinearLayout>

</ScrollView>